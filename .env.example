# Copy this file to .env and fill in real values. Never commit .env.

# WhatsApp Business API (Meta Cloud API or provider of choice)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# AI provider (for plain-language summarization)
AI_PROVIDER_API_KEY=

# Database (Supabase or equivalent)
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# App config
NODE_ENV=development
LOG_LEVEL=info

# Data retention (days) — see docs/ETHICS.md for rationale on defaults
TENDER_CONTENT_RETENTION_DAYS=30
