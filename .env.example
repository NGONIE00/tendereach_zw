# Copy this file to .env and fill in real values. Never commit .env.

# WhatsApp Business API (Meta Cloud API or provider of choice)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Messenger (Facebook Page) — see docs/MULTI_CHANNEL_ARCHITECTURE.md
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=

# Instagram (via the linked Facebook Page) — see docs/MULTI_CHANNEL_ARCHITECTURE.md
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

# AI provider (for plain-language summarization)
AI_PROVIDER_API_KEY=

# Database (Supabase or equivalent)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Airtable CRM (see docs/CRM_SCHEMA.md)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_FOUNDING_SUPPLIERS_TABLE=Founding Suppliers

# App config
NODE_ENV=development
LOG_LEVEL=info

# Data retention (days) — see docs/ETHICS.md for rationale on defaults
TENDER_CONTENT_RETENTION_DAYS=30

# Rate limiting (see SECURITY.md)
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_MS=600000
